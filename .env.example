# --- GENERAL ---
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# --- MONGODB ---
MONGODB_URI=mongodb://localhost:27017/ikip_production
MONGODB_DB_NAME=ikip_production

# --- REDIS ---
REDIS_URL=redis://localhost:6379

# --- NEO4J ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# --- QDRANT ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=ikip_chunks

# --- GOOGLE AI (GEMINI) ---
GOOGLE_AI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- AUTH ---
JWT_SECRET=super_secret_session_jwt_key_that_is_at_least_32_characters_long_12345
JWT_REFRESH_SECRET=super_secret_refresh_jwt_key_that_is_at_least_32_characters_long_12345
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# --- AI SERVICES (internal) ---
# Use http://ai-services:8000 for docker setup, http://localhost:8000 for local execution
AI_SERVICES_URL=http://localhost:8000
AI_SERVICES_API_KEY=secret_ai_token_key_here

# --- FILE UPLOAD ---
MAX_FILE_SIZE_MB=100
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/tiff,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# --- RATE LIMITING ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
QUERY_RATE_LIMIT_PER_MINUTE=30

# --- COMPLIANCE SCHEDULER ---
COMPLIANCE_SCAN_CRON=0 2 * * *
LESSONS_ANALYSIS_CRON=*/30 * * * *

# --- MONITORING ---
PROMETHEUS_PORT=9090
LOG_LEVEL=info
